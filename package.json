{
  "name": "deephaven-plugins",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "./plugins/*/src/js/"
  ],
  "scripts": {
    "docker": "docker compose up deephaven-plugins --build",
    "start": "run-p \"start:packages -- {@}\" serve:plugins --",
    "build": "npm run build --workspaces --if-present",
    "types": "tsc",
    "watch:types": "tsc --watch",
    "serve:plugins": "vite",
    "start:packages": "lerna run start --stream --concurrency 20",
    "docs": "./tools/run_docker.sh ./docker-compose.docs.yml docs",
    "test": "jest --watch --changedSince origin/main",
    "test:unit": "jest --config jest.config.unit.cjs",
    "test:lint": "jest --config jest.config.lint.cjs",
    "test:remote-file-source": "./tools/test_remote_file_source.sh",
    "test:ci": "run-p test:ci:*",
    "test:ci:unit": "jest --config jest.config.unit.cjs --ci --cacheDirectory $PWD/.jest-cache",
    "test:ci:lint": "jest --config jest.config.lint.cjs --ci --cacheDirectory $PWD/.jest-cache",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:docker": "DEEPHAVEN_PORT=10001 ./tools/run_docker.sh ./tests/docker-compose.yml e2e-tests",
    "e2e:update-snapshots": "./tools/run_docker.sh ./tests/docker-compose.yml update-snapshots",
    "update-dh-packages": "lerna run --concurrency 1 update-dh-packages",
    "update-dh-packages:ui": "npm run update-dh-packages -- --scope=@deephaven/js-plugin-ui --",
    "update-doc-snapshots": "./tools/run_docker.sh ./docker-compose.docs-snapshots.yml deephaven-plugins-docs-snapshotter",
    "validate-doc-snapshots": "./tools/run_docker.sh ./docker-compose.docs-snapshots.yml deephaven-plugins-docs-validator"
  },
  "devDependencies": {
    "@deephaven/babel-preset": "^1.8.0",
    "@deephaven/eslint-config": "^1.1.0",
    "@deephaven/prettier-config": "^1.1.0",
    "@deephaven/tsconfig": "^1.1.0",
    "@playwright/test": "^1.44.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.2.5",
    "@types/node": "^20.11.17",
    "@types/prop-types": "^15.7.10",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "conventional-changelog-conventionalcommits": "^7.0.0",
    "eslint": "^8.37.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.6.2",
    "jest-canvas-mock": "^2.4.0",
    "jest-environment-jsdom": "^29.6.2",
    "jest-runner-eslint": "^1.1.0",
    "jest-runner-stylelint": "^2.3.7",
    "jest-watch-select-projects": "^2.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "lerna": "^9.0.1",
    "npm-run-all": "^4.1.5",
    "nx": "^22.2.1",
    "prettier": "3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.6"
  },
