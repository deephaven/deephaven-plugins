{
  "name": "@deephaven/js-plugin-tradingview-lightweight",
  "version": "0.1.0",
  "description": "Deephaven TradingView Lightweight Charts plugin",
  "keywords": [
    "Deephaven",
    "plugin",
    "deephaven-js-plugin",
    "tradingview",
    "lightweight-charts"
  ],
  "author": "Deephaven Data Labs LLC",
  "license": "Apache-2.0",
  "main": "dist/bundle/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/bundle/index.js",
      "default": "./dist/bundle/index.js"
    },
    "./*.js": "./dist/*.js",
    "./*": "./dist/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deephaven/deephaven-plugins"
  },
  "bugs": {
    "url": "https://github.com/deephaven/deephaven-plugins/issues"
  },
  "homepage": "https://github.com/deephaven/deephaven-plugins",
  "scripts": {
    "start": "vite build --watch",
    "build": "run-s build:*",
    "build:transpile": "tsc",
    "build:bundle": "vite build",
    "update-dh-packages": "node ../../../../tools/update-dh-packages.mjs"
  },
  "devDependencies": {
    "@deephaven/dashboard-core-plugins": "^0.85.42",
    "@deephaven/jsapi-types": "^1.0.0-dev0.39.5",
    "@deephaven/test-utils": "0.105.0",
    "@types/react": "^17.0.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "dependencies": {
    "@deephaven/components": "^1.2.0",
    "@deephaven/dashboard": "^1.2.0",
    "@deephaven/icons": "^1.2.0",
    "@deephaven/jsapi-bootstrap": "1.2.0",
    "@deephaven/log": "1.1.0",
    "@deephaven/plugin": "^1.2.0",
    "@deephaven/utils": "^1.1.0",
    "lightweight-charts": "^5.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
